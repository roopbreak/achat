{
  "name": "achat",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "start": "node index.mjs",
    "dev": "NODE_ENV=development node --watch index.mjs",
    "contracts:build": "npm run build -w @achat/contracts",
    "build:frontend": "cd frontend && npm install && npm run build"
  },
  "dependencies": {
    "@achat/contracts": "*",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "multer": "^1.4.5-lts.1"
  }
}
